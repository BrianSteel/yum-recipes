{
  "name": "foodify",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:dev:restart": "docker-compose -f docker-compose.dev.yml restart",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up",
    "docker:prod:build": "docker-compose -f docker-compose.prod.yml up --build",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:scale": "docker-compose -f docker-compose.dev.yml up --scale backend=3",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:logs:backend": "docker-compose -f docker-compose.dev.yml logs -f backend",
    "docker:logs:frontend": "docker-compose -f docker-compose.dev.yml logs -f frontend",
    "docker:logs:nginx": "docker-compose -f docker-compose.dev.yml logs -f nginx",
    "seed": "docker-compose -f docker-compose.dev.yml exec backend node migration-scripts/seed.js",
    "nginx:reload": "docker-compose -f docker-compose.dev.yml exec nginx nginx -s reload",
    "test:backend": "cd backend && npm test"
  }
}
